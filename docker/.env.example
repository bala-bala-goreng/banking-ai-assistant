# Copy to .env and adjust as needed — every value has a working default in docker-compose.yml

POSTGRES_DB=bankdb
POSTGRES_USER=bank
POSTGRES_PASSWORD=bank

# Must be at least 32 characters (HMAC-SHA256 key)
JWT_SECRET=dev-only-secret-change-me-0123456789abcdef

# Phase 2+: where the backend reaches Ollama.
# - `docker compose --profile ai up`  -> http://ollama:11434 (default)
# - Ollama installed on the host      -> http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434
